---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>A Jammin Life</title>

    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <header>
      <a class="brand" href="/">
        <img src="/images/logo.png" alt="A Jammin Life logo" />
        <span>A Jammin Life</span>
      </a>

      <button class="menu-button" id="menuButton" aria-label="Open menu">
        ☰
      </button>

      <nav id="menu">
        <a href="/orderform">Preorder</a>
        <a href="/about">About Me</a>
        <a href="/blog">Blog</a>
      </nav>
    </header>

    <main>
      <section class="intro">
        <p>
          Artisanal Flavors from Seoul to Your Soul: Unveiling the Art of
          Korean Baking and Cooking
        </p>
      </section>

      <img
        src="/images/homepage.jpeg"
        alt="Pumpkin Cheesecake"
        class="hero-image"
      />
    </main>

<section class="bottom-row">
  <div class="subscribe-wrapper">
  <h3>Join the Jammin Community</h3>

  <p>
    New menus, drops, and stories of the Jammin Life delivered to your inbox.
  </p>

  <form
    class="subscribe"
    action="https://buttondown.com/api/emails/embed-subscribe/ajamminlife"
    method="post"
    target="popupwindow"
    onsubmit="window.open('https://buttondown.com/ajamminlife', 'popupwindow')"
  >
    <input
      type="email"
      name="email"
      placeholder="your email (:"
      required
    />

    <button type="submit">Join</button>
  </form>
</div>

  <div class="socials">
    <a href="https://www.instagram.com/ajamminlife/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
      <img src="/images/instagram.png" alt="Instagram" />
    </a>

    <a href="https://www.youtube.com/@itsajamminlife" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
      <img src="/images/youtube.png" alt="YouTube" />
    </a>

    <a href="https://www.tiktok.com/@itsajamminlife" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
      <img src="/images/tiktok.png" alt="TikTok" />
    </a>
  </div>
</section>

    <script>
      const button = document.getElementById("menuButton");
      const menu = document.getElementById("menu");

      button?.addEventListener("click", () => {
        menu?.classList.toggle("open");
      });
    </script>
  </body>
</html>

<style>

 * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #ffffff;
    color: #252525;
    font-family: "Josefin Sans", sans-serif;
  }

  header {
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 4rem;
    position: relative;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    text-decoration: none;
    color: #252525;
  }

  .brand img {
    width: 62px;
    height: 62px;
    object-fit: contain;
  }

  .brand span {
    font-size: 1.7rem;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .menu-button {
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    color: #252525;
  }

  nav {
    display: none;
    position: absolute;
    top: 80px;
    right: 4rem;
    background: white;
    padding: 1.5rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    z-index: 10;
  }

  nav.open {
    display: grid;
    gap: 1rem;
  }

  nav a {
    color: #252525;
    text-decoration: none;
    font-size: 1rem;
    letter-spacing: 0.08em;
  }

  .intro {
    text-align: center;
    padding: 3.5rem 1rem 2rem;
  }

  .intro p {
    margin: 0 auto;
    max-width: 850px;
    font-size: 1.15rem;
    letter-spacing: 0.05em;
    line-height: 1.6;
  }

  .hero-image {
	width: 100%;
  	max-width: 900px;
  	height: auto;
  	display: block;
  	margin: 0 auto;
  	border-radius: 12px;
}
.bottom-row {
  width: 100%;
  padding: 3rem 6rem 4rem;
  box-sizing: border-box;

  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 3rem;
}

.subscribe-wrapper {
  width: 650px;
  max-width: 65%;
  margin: 0;
}

.subscribe-wrapper h3 {
  margin: 0 0 0.4rem;
  font-size: 1.25rem;
  font-weight: 500;
  text-align: left;
}

.subscribe-wrapper p {
  margin: 0 0 1rem;
  font-size: 1rem;
  line-height: 1.5;
  color: #666;
  text-align: left;
}

.subscribe {
  display: flex;
  width: 100%;
  margin: 0;
}

.subscribe input {
  min-width: 0;
  flex: 1;
  padding: 1rem 1.25rem;
  border: 1px solid #cfd8dc;
  font-family: "Josefin Sans", sans-serif;
  font-size: 1rem;
}

.subscribe button {
  flex-shrink: 0;
  padding: 1rem 1.5rem;
  border: none;
  background: #174e63;
  color: #ffffff;
  font-family: "Josefin Sans", sans-serif;
  font-size: 1rem;
  cursor: pointer;
}

.subscribe button:hover {
  background: #123d4d;
}

.socials {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  align-items: center;
  gap: 1rem;
  flex-shrink: 0;
  margin: 0;
}

.socials a {
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  text-decoration: none;
}

.socials img {
  width: 32px;
  height: 32px;
  max-width: 32px;
  max-height: 32px;
  object-fit: contain;
  display: block;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.socials img:hover {
  transform: scale(1.12);
  opacity: 0.75;
}

@media (max-width: 800px) {
  html,
  body {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
  }

  header {
    width: 100%;
    height: 80px;
    padding: 0 1.25rem;
    box-sizing: border-box;
  }

  .brand {
    min-width: 0;
  }

  .brand img {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }

  .brand span {
    font-size: 1.25rem;
    white-space: nowrap;
  }

  nav {
    top: 70px;
    right: 1.25rem;
  }

  .menu-button {
    flex-shrink: 0;
  }

  main {
    width: 100%;
  }

  .intro {
    width: 100%;
    padding: 3rem 1.25rem 2rem;
    box-sizing: border-box;
  }

  .intro p {
    max-width: 460px;
    margin: 0 auto;
  }

  .hero-image {
    width: calc(100% - 2rem);
    max-width: 520px;
    height: auto;
    margin: 0 auto;
    object-fit: cover;
  }

  .bottom-row {
    width: 100%;
    padding: 3rem 1.25rem 4rem;

    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .subscribe-wrapper {
    width: 100%;
    max-width: 520px;
  }

  .subscribe-wrapper h3,
  .subscribe-wrapper p {
    text-align: left;
  }

  .subscribe {
    width: 100%;
  }

  .subscribe input {
    width: 0;
    min-width: 0;
    flex: 1 1 auto;
  }

  .subscribe button {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  .socials {
    width: 100%;
    justify-content: center;
    gap: 1.25rem;
  }
}

</style>