<style>
body {
  font-family: "Josefin Sans", sans-serif;
  background: white;
}

.blog-page {
  max-width: 1400px;
  margin: 0 auto;
  padding: 2rem;
}

.kitchen {
  margin-bottom: 6rem;
}

.kitchen h1,
.jammin h1 {
  font-size: 2.5rem;
  margin-bottom: 2rem;
}

.article-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 3rem;
}

.article-grid article {
  min-height: 120px;
}

.article-grid h2 {
  font-size: 1.5rem;
  line-height: 1.4;
}

.jammin-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 3rem;
}

.card img {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
}

.card h2 {
  font-size: 1.5rem;
  line-height: 1.4;
}
.blog-page a {
  color: #111;
  text-decoration: none;
}

.blog-page a:hover {
  text-decoration: underline;
}

@media (max-width: 900px) {

  .article-grid,
  .jammin-grid {
    grid-template-columns: repeat(2, 1fr);
  }

}
</style>