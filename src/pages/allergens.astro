---
import Header from "../components/Header.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <title>Allergen Information | A Jammin Life</title>

    <link rel="icon" type="image/png" href="/favicon.png?v=2" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <Header />

    <main class="allergen-page">
      <section class="intro">
        <p class="eyebrow">July 25, 2026 Pastry Drop</p>

        <h1>Allergen Information</h1>

        <p>
          Please review the allergen information for each pastry carefully
          before placing your order. Recipes and ingredients may change from
          one pastry drop to the next.
        </p>
      </section>

      <section class="allergen-list">
        <article class="allergen-card">
          <h2>Coconut with Caramel Drizzle</h2>

          <p class="section-label">Contains:</p>

          <ul>
            <li>Wheat / Gluten</li>
            <li>Dairy</li>
            <li>Eggs</li>
            <li>Almond</li>
            <li>Coconut</li>
          </ul>
        </article>

        <article class="allergen-card">
          <h2>Cream Cheese and Cardamom Blueberry</h2>

          <p class="section-label">Contains:</p>

          <ul>
            <li>Wheat / Gluten</li>
            <li>Dairy</li>
            <li>Eggs</li>
            <li>Almond</li>
          </ul>
        </article>

        <article class="allergen-card">
          <h2>Ube with Malted Milk Streusel</h2>

          <p class="section-label">Contains:</p>

          <ul>
            <li>Wheat / Gluten</li>
            <li>Dairy</li>
            <li>Eggs</li>
            <li>Almond</li>
          </ul>

        </article>

        <article class="allergen-card">
          <h2>Matcha and Raspberry Jam</h2>

          <p class="section-label">Contains:</p>

          <ul>
            <li>Wheat / Gluten</li>
            <li>Dairy</li>
            <li>Eggs</li>
            <li>Almond</li>
          </ul>
        </article>


        <article class="allergen-card">
          <h2>Toasted Sugar and Lemon</h2>

          <p class="section-label">Contains:</p>

          <ul>
            <li>Wheat / Gluten</li>
            <li>Dairy</li>
            <li>Eggs</li>
            <li>Almond</li>
          </ul>
        </article>

        <article class="allergen-card">
          <h2>Classic Pastel de Nata</h2>

          <p class="section-label">Contains:</p>

          <ul>
            <li>Wheat / Gluten</li>
            <li>Dairy</li>
            <li>Eggs</li>
          </ul>
        </article>


       <article class="allergen-card">
          <h2>Pistachio Choux aux Craquelin</h2>

          <p class="section-label">Contains:</p>

          <ul>
            <li>Wheat / Gluten</li>
            <li>Dairy</li>
            <li>Eggs</li>
            <li>Pistachio</li>
          </ul>
        </article>

        <article class="allergen-card">
          <h2>Earl Grey Choux aux Craquelin</h2>

          <p class="section-label">Contains:</p>

          <ul>
            <li>Wheat / Gluten</li>
            <li>Dairy</li>
            <li>Eggs</li>
          </ul>
        </article>


      </section>


      <section class="kitchen-notice">
        <h2>Important Kitchen Notice</h2>

        <p>
          All pastries are prepared in a home kitchen that also handles common
          allergens, including wheat, milk, eggs, soy, peanuts, tree nuts,
          sesame, and other ingredients.
        </p>

        <p>
          Although care is taken during preparation, cross-contact cannot be
          guaranteed. Customers with severe or life-threatening allergies
          should not place an order.
        </p>
      </section>

      <a class="back-link" href="/preorder">
        ← Return to this week’s pastry drop
      </a>
    </main>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #ffffff;
    color: #252525;
    font-family: "Josefin Sans", sans-serif;
  }

  .allergen-page {
    width: min(900px, calc(100% - 4rem));
    margin: 0 auto;
    padding: 5rem 0 6rem;
  }

  .intro {
    max-width: 760px;
    margin: 0 auto 3.5rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: #777;
    font-size: 0.9rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 1.5rem;
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 400;
    line-height: 1.1;
  }

  .intro > p:last-child {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.7;
  }

  .allergen-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .allergen-card {
    padding: 2rem;
    border: 1px solid #d7d7d7;
    background: #ffffff;
  }

  .allergen-card h2 {
    margin: 0 0 1rem;
    font-size: 1.55rem;
    font-weight: 500;
    line-height: 1.3;
  }
.section-label {
  margin: 1.25rem 0 0.65rem;
  font-size: 1rem;
  font-weight: 600;
  color: #252525;
}

  .allergen-card ul {
    margin: 0;
    padding-left: 1.25rem;
  }

  .allergen-card li {
    margin-bottom: 0.45rem;
    font-size: 1.1rem;
    line-height: 1.5;
  }

  .allergen-card li:last-child {
    margin-bottom: 0;
  }

  .kitchen-notice {
    margin-top: 3rem;
    padding: 2.25rem;
    border: 1px solid #cfcfcf;
    text-align: center;
  }

  .kitchen-notice h2 {
    margin: 0 0 1rem;
    font-size: 1.85rem;
    font-weight: 500;
  }

  .kitchen-notice p {
    margin: 0 0 1rem;
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .kitchen-notice p:last-child {
    margin-bottom: 0;
  }

  .back-link {
    display: block;
    width: fit-content;
    margin: 2.75rem auto 0;
    color: #b43b3b;
    font-size: 1.05rem;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .back-link:hover {
    opacity: 0.7;
  }

  @media (max-width: 700px) {
    .allergen-page {
      width: calc(100% - 2.5rem);
      padding: 3.5rem 0 4.5rem;
    }

    .intro {
      margin-bottom: 2.5rem;
    }

    .intro > p:last-child {
      font-size: 1.1rem;
    }

    .allergen-list {
      grid-template-columns: 1fr;
    }

    .allergen-card {
      padding: 1.5rem;
    }

    .kitchen-notice {
      padding: 1.5rem;
    }
  }
</style>